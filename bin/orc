#!/usr/bin/env -S /home/ryan/Code/orchestrel/node_modules/.bin/tsx

import arg from 'arg';
import Database from 'better-sqlite3';
import { existsSync, readFileSync, writeFileSync, mkdirSync, renameSync, chmodSync } from 'fs';
import { dirname, resolve } from 'path';
import { fileURLToPath } from 'url';
import { spawn } from 'child_process';
import { getAgentDir } from '@earendil-works/pi-coding-agent';
import { buildModelAliasEnv, parseConfig } from '../src/shared/config.ts';

const SCRIPT_DIR = dirname(fileURLToPath(import.meta.url));
const REPO_ROOT = resolve(SCRIPT_DIR, '..');
const DEFAULT_CONFIG_PATH = resolve(REPO_ROOT, 'config.yaml');
const DEFAULT_PI_PATH = resolve(REPO_ROOT, 'node_modules', '.bin', 'pi');
const DEFAULT_DB_PATH = resolve(REPO_ROOT, 'data', 'orchestrel.db');
const ENV_DEFAULT_PROVIDER = 'ORC_PROVIDER';
const ENV_DEFAULT_MODEL = 'ORC_MODEL';
const LEGACY_SKIP_PERMISSIONS_FLAG = '--dangerously-skip-permissions';

const args = arg(
  {
    '--help': Boolean,
    '-h': '--help',
    '--config': String,
    '--print-env': Boolean,
    '--prompt': String,
    '-p': '--prompt',
  },
  {
    permissive: true,
  },
);

function usage() {
  return [
    'Usage: orc [options] [pi args...] [provider model]',
    '',
    'Examples:',
    '  orc trackable auto',
    '  orc --resume abc123 trackable auto   # resume session abc123 directly',
    '  orc --resume trackable auto          # open the session picker',
    '  orc -p "what time is it?" trackable auto',
    '  orc --print-env trackable auto',
    '',
    'Options:',
    '  --config <path>   Override config.yaml path',
    '  --print-env       Print resolved env/model and exit',
    '  -p, --prompt      Run a one-shot prompt through Pi',
    '  -h, --help        Show help',
    '',
    'Environment:',
    '  ORC_PROVIDER      Default provider when no provider arg is present',
    '  ORC_MODEL         Default model when no model arg is present',
  ].join('\n');
}

function main() {
  if (args['--help']) {
    process.stdout.write(`${usage()}\n`);
    return;
  }

  const configPath = resolveConfigPath(args['--config']);
  const config = loadWrapperConfig(configPath);
  const passthroughArgs = [...args._];
  stripSkipPermissionsFlag(passthroughArgs);
  const resumeTarget = extractResumeTarget(passthroughArgs);
  rewriteResumeToSession(passthroughArgs, config);

  const prompt = args['--prompt'];
  const resolved = extractProviderAndModel(config, passthroughArgs, resumeTarget);
  const provider = config.providers[resolved.providerId];
  if (!provider) {
    throw new Error(`Unknown provider "${resolved.providerId}" in ${configPath}`);
  }

  const model = provider.models[resolved.modelAlias];
  if (!model) {
    throw new Error(`Unknown model alias "${resolved.modelAlias}" for provider "${resolved.providerId}"`);
  }

  rejectConflictingArgs(passthroughArgs);
  // Qualify the model with its provider — a bare model id like "auto" is
  // ambiguous (pi's built-in openrouter also has "auto") and pi rejects
  // ambiguous bare ids. "provider/id" resolves to exactly our provider.
  const modelSpec = `${resolved.providerId}/${model.modelID}`;
  const piArgs = buildPiArgs(modelSpec, passthroughArgs, prompt);

  const env = buildPiEnv(provider);
  if (args['--print-env']) {
    process.stdout.write(
      JSON.stringify(
        {
          provider: resolved.providerId,
          modelAlias: resolved.modelAlias,
          modelID: model.modelID,
          ...(resolved.card ? { card: resolved.card } : {}),
          env,
          passthroughArgs,
          piArgs,
          piPath: resolvePiPath(),
          configPath,
        },
        null,
        2,
      ) + '\n',
    );
    return;
  }

  // Pi (the binary) only knows its built-in providers plus whatever is in
  // ~/.pi/agent/models.json. orcd registers custom providers programmatically
  // via the SDK, but this standalone wrapper spawns the pi binary, so we must
  // materialize custom providers to models.json or pi rejects the model ID.
  syncModelsJson(config);

  const piPath = requirePiPath();
  const child = spawn(
    piPath,
    piArgs,
    {
      stdio: 'inherit',
      env: {
        ...process.env,
        ...env,
      },
    },
  );

  child.on('exit', (code, signal) => {
    if (signal) {
      process.kill(process.pid, signal);
      return;
    }
    process.exit(code ?? 0);
  });

  child.on('error', (err) => {
    console.error(`orc: failed to launch pi: ${err.message}`);
    process.exit(1);
  });
}

function resolveConfigPath(override) {
  if (override) return resolve(override);
  if (process.env.ORC_CONFIG) return resolve(process.env.ORC_CONFIG);
  return DEFAULT_CONFIG_PATH;
}

function loadWrapperConfig(configPath) {
  if (!existsSync(configPath)) {
    throw new Error(`Config not found at ${configPath}`);
  }
  return parseConfig(readFileSync(configPath, 'utf8'), process.env);
}

function extractProviderAndModel(config, passthroughArgs, resumeTarget) {
  for (let i = 0; i < passthroughArgs.length; i += 1) {
    const maybeProvider = passthroughArgs[i];
    if (!maybeProvider) continue;

    const provider = config.providers[maybeProvider];
    if (!provider) continue;

    const maybeModel = passthroughArgs[i + 1];
    if (maybeModel) {
      const modelAlias = tryResolveModelAlias(provider, maybeModel);
      if (modelAlias) {
        passthroughArgs.splice(i, 2);
        return {
          providerId: maybeProvider,
          modelAlias,
        };
      }
    }

    const trailingModel = args['--prompt'] ? findPromptTrailingModel(provider, passthroughArgs, i) : null;
    if (trailingModel) {
      return {
        providerId: maybeProvider,
        modelAlias: trailingModel,
      };
    }

    passthroughArgs.splice(i, 1);
    // Explicit provider, no model: use the provider's first-listed model.
    // ORC_MODEL is a global default paired with ORC_PROVIDER; it must not
    // leak across to a provider the user named explicitly.
    return {
      providerId: maybeProvider,
      modelAlias: firstModelAlias(provider),
    };
  }

  if (resumeTarget) {
    const card = findCardBySessionId(resumeTarget);
    if (card) {
      const resumedProvider = config.providers[card.provider];
      if (!resumedProvider) {
        throw new Error(`Card ${card.id} uses unknown provider "${card.provider}"`);
      }
      return {
        providerId: card.provider,
        modelAlias: resolveModelAlias(resumedProvider, card.model),
        card,
      };
    }
  }

  return resolveDefaultProviderAndModel(config);
}

function findPromptTrailingModel(provider, passthroughArgs, providerIndex) {
  const lastIndex = passthroughArgs.length - 1;
  if (lastIndex <= providerIndex) return null;
  const modelAlias = tryResolveModelAlias(provider, passthroughArgs[lastIndex]);
  if (!modelAlias) return null;
  passthroughArgs.splice(lastIndex, 1);
  passthroughArgs.splice(providerIndex, 1);
  return modelAlias;
}

function resolveDefaultProviderAndModel(config) {
  const providerId = envDefault(ENV_DEFAULT_PROVIDER) ?? config.defaultProvider;
  const provider = config.providers[providerId];
  if (!provider) {
    throw new Error(`Unknown provider "${providerId}"`);
  }

  return {
    providerId,
    modelAlias: resolveModelAlias(provider, envDefault(ENV_DEFAULT_MODEL) ?? config.defaultModel),
  };
}

function envDefault(name) {
  const value = process.env[name];
  return value ? value : null;
}

function tryResolveModelAlias(provider, modelRef) {
  try {
    return resolveModelAlias(provider, modelRef);
  } catch {
    return null;
  }
}

function extractResumeTarget(passthroughArgs) {
  for (let i = 0; i < passthroughArgs.length; i += 1) {
    const token = passthroughArgs[i];
    if (token === '--resume') {
      return passthroughArgs[i + 1] ?? null;
    }
    if (token?.startsWith('--resume=')) {
      return token.slice('--resume='.length);
    }
  }
  return null;
}

// Pi's `--resume`/`-r` is a bare boolean that always opens the interactive
// session picker — it never consumes the id after it. Resume-by-id in pi is a
// separate flag, `--session <id>` (matches by exact id or id-prefix, opens
// immediately). So when the user passes `--resume <id>`, rewrite it to
// `--session <id>` before handing off. A bare `--resume` (no id, or followed by
// a provider/flag) is left alone so the picker still works.
function rewriteResumeToSession(passthroughArgs, config) {
  for (let i = 0; i < passthroughArgs.length; i += 1) {
    const token = passthroughArgs[i];
    let id = null;
    let pairLen = 0;
    if (token === '--resume' || token === '-r') {
      id = passthroughArgs[i + 1] ?? null;
      pairLen = 2;
    } else if (token?.startsWith('--resume=')) {
      id = token.slice('--resume='.length);
      pairLen = 1;
    } else {
      continue;
    }
    // Only a real session id gets rewritten; a flag or known provider means the
    // user wants the picker (optionally scoped by a following provider arg).
    if (!id || id.startsWith('-') || config.providers[id]) return;
    passthroughArgs.splice(i, pairLen, '--session', id);
    return;
  }
}

function findCardBySessionId(sessionId) {
  const dbPath = resolveDbPath();
  if (!existsSync(dbPath)) return null;

  const db = new Database(dbPath, { readonly: true, fileMustExist: true });
  try {
    const row = db
      .prepare(
        'select id, title, provider, model from cards where session_id = ? order by updated_at desc limit 1',
      )
      .get(sessionId);
    if (!row) return null;
    return {
      id: row.id,
      title: row.title,
      provider: row.provider,
      model: row.model,
    };
  } finally {
    db.close();
  }
}

function resolveModelAlias(provider, modelRef) {
  if (!provider) {
    throw new Error(`Unknown provider "${String(modelRef)}"`);
  }

  if (provider.models[modelRef]) {
    return modelRef;
  }

  const claudeDefaultAlias = resolveClaudeDefaultModelAlias(provider, modelRef);
  if (claudeDefaultAlias) {
    return claudeDefaultAlias;
  }

  for (const [alias, model] of Object.entries(provider.models)) {
    if (model.modelID === modelRef) {
      return alias;
    }
  }

  throw new Error(`Unknown model "${modelRef}" for provider`);
}

function resolveClaudeDefaultModelAlias(provider, modelRef) {
  const aliases = Object.keys(provider.models);
  const [opus, sonnet = opus, haiku = sonnet] = aliases;
  const claudeAliases = {
    opus,
    sonnet,
    haiku,
  };

  return claudeAliases[modelRef] ?? null;
}

function firstModelAlias(provider) {
  const alias = Object.keys(provider.models)[0];
  if (!alias) {
    throw new Error('Provider has no configured models');
  }
  return alias;
}

function resolveDbPath() {
  if (process.env.ORC_DB_PATH) return resolve(process.env.ORC_DB_PATH);
  return DEFAULT_DB_PATH;
}

function stripSkipPermissionsFlag(passthroughArgs) {
  for (let i = passthroughArgs.length - 1; i >= 0; i -= 1) {
    if (passthroughArgs[i] === LEGACY_SKIP_PERMISSIONS_FLAG) {
      passthroughArgs.splice(i, 1);
    }
  }
}

function rejectConflictingArgs(passthroughArgs) {
  for (const token of passthroughArgs) {
    if (token === '--model' || token === '-m' || token.startsWith('--model=')) {
      throw new Error('Do not pass --model to orc; use positional provider and model instead.');
    }
  }
}

// Mirror orcd's registerOrchestrelProvider: every config provider that isn't
// pi's built-in anthropic (i.e. has a baseUrl) gets written to models.json so
// the pi binary can resolve its model IDs. Built-in anthropic (Claude Max
// OAuth, no baseUrl) is left untouched.
function syncModelsJson(config) {
  const providers = {};
  for (const [id, provider] of Object.entries(config.providers)) {
    if (!provider.baseUrl) continue;
    const api = provider.type === 'bedrock' ? 'bedrock-converse-stream' : 'anthropic-messages';
    const apiKey = provider.apiKey || provider.authToken;
    providers[id] = {
      name: provider.label ?? id,
      api,
      baseUrl: provider.baseUrl,
      ...(apiKey ? { apiKey } : {}),
      models: Object.entries(provider.models).map(([alias, model]) => ({
        id: model.modelID,
        name: model.label ?? alias,
        api,
        reasoning: provider.type === 'anthropic',
        input: ['text', 'image'],
        cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
        contextWindow: model.contextWindow,
        maxTokens: 64000,
      })),
    };
  }

  // models.json holds provider apiKey/authToken, so keep it owner-only.
  const modelsPath = resolve(getAgentDir(), 'models.json');
  const dir = dirname(modelsPath);
  mkdirSync(dir, { recursive: true, mode: 0o700 });
  chmodSync(dir, 0o700);
  const tmp = `${modelsPath}.orc-tmp`;
  writeFileSync(tmp, JSON.stringify({ providers }, null, 2) + '\n', { mode: 0o600 });
  renameSync(tmp, modelsPath);
}

function buildPiEnv(provider) {
  // Provider baseUrl/auth reach pi via ~/.pi/agent/models.json (see syncModelsJson),
  // not env — pi ignores PI_BASE_URL/PI_API_KEY/PI_AUTH_TOKEN. The only env pi
  // consumes here is the ANTHROPIC_DEFAULT_*_MODEL alias map for subagent tiers.
  return buildModelAliasEnv(provider.models);
}

function buildPiArgs(modelId, passthroughArgs, prompt) {
  if (prompt !== undefined) return ['--model', modelId, '--mode', 'json', '-p', prompt, ...passthroughArgs];
  return ['--model', modelId, ...passthroughArgs];
}

function resolvePiPath() {
  const override = process.env.ORC_PI_PATH;
  if (override) return override;
  return DEFAULT_PI_PATH;
}

function requirePiPath() {
  const p = resolvePiPath();
  if (!existsSync(p)) throw new Error(`pi not found at ${p}`);
  return p;
}

try {
  main();
} catch (err) {
  console.error(`orc: ${err instanceof Error ? err.message : String(err)}`);
  process.exit(1);
}
