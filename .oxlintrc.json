{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react"],
  "jsPlugins": ["./oxlint-plugins/orchestrel.js"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "ignoreRestSiblings": true }],
    "react-hooks/exhaustive-deps": "warn",
    "orchestrel/no-overflow-auto": "error",
    "orchestrel/log-in-catch": "warn",
    "orchestrel/log-before-early-return": "warn"
  },
  "ignorePatterns": ["node_modules", "build", ".react-router", "data", ".worktrees"]
}
