    "class-transformer": "^0.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "idb-keyval": "^6.2.2",
    "isbot": "^5.1.31",
